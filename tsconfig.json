{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,            
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,          
    "isolatedModules": true,            
    "verbatimModuleSyntax": true,       
    "target": "ES2022",                  
    "rootDir": "./src",                  
    "strict": true,                      
    "skipLibCheck": true,                
    "outDir": "./dist"
  },
  "include": ["src/**/*"],              
  "exclude": ["node_modules", "dist"]   
}
